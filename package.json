{
  "name": "reasonloop",
  "version": "0.1.0",
  "description": "A reasoning middleware that sits between agents and language models",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "reasonloop": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "start": "node dist/cli/index.js start"
  },
  "keywords": [
    "llm",
    "reasoning",
    "middleware",
    "proxy",
    "agent"
  ],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@fastify/cors": "^11.2.0",
    "@fastify/rate-limit": "^11.0.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-trace-node": "^2.8.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "better-sqlite3": "^12.10.0",
    "chalk": "^5.6.2",
    "commander": "^15.0.0",
    "fastify": "^5.8.5",
    "openai": "^6.42.0",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.3",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
